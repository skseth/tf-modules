[mysqld]
server_id = 2
binlog_format = ROW
log-bin = mysql-bin
relay-log=mysql-relay-bin
gtid_mode = ON
enforce_gtid_consistency = ON
default-authentication-plugin=mysql_native_password
innodb_buffer_pool_size = 256M
max_connections         = 200
slow_query_log          = 1
long_query_time         = 1

